# Resend (https://resend.com) — required for the registration form to send emails.
# 1. Create a free account at resend.com
# 2. Create an API key (Dashboard > API Keys)
# 3. Copy it into a local .env.local file (not committed) as RESEND_API_KEY
RESEND_API_KEY=

# Sender address. Until a domain is verified in Resend, you must use the
# sandbox address below — real custom domains require domain verification.
RESEND_FROM_EMAIL="Forte Institute <onboarding@resend.dev>"

# Inbox that receives new registration notifications.
FORTE_NOTIFY_EMAIL=connectwithforte@gmail.com
